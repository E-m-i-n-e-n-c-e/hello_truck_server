
# Check server url https://hello-truck-server.fly.dev/
@base_url = http://localhost:3000

POST {{base_url}}/auth/driver/send-otp
Content-Type: application/json

{
  "phoneNumber": "6300045929"
}

### Verify OTP
POST {{base_url}}/auth/driver/verify-otp
Content-Type: application/json

{
  "phoneNumber": "6300045929",
  "otp": "123456"
}

